# Copy to .env.local for local overrides (git-ignored).
#
# Base URL of the backend API, including the /api suffix.
# Leave unset for local development — the Vite dev server proxies /api to
# http://localhost:3001 (see vite.config.ts).
#
# VITE_API_URL=https://your-backend.example.com/api

# Shared secret matching the backend's API_KEY env var (see
# backend/src/middleware/apiKey.ts). Only needed when the backend enforces
# one — leave unset for local dev where the backend has no API_KEY set.
# VITE_API_KEY=
